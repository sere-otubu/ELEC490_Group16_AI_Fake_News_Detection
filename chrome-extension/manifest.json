{
    "manifest_version": 3,
    "name": "MedCheck AI - Fake News Detector",
    "version": "1.0.0",
    "description": "Right-click highlighted text on any webpage to verify medical claims against peer-reviewed evidence using AI.",
    "permissions": [
        "contextMenus",
        "activeTab"
    ],
    "host_permissions": [
        "http://localhost:*/*",
        "http://127.0.0.1:*/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "css": [
                "content.css"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}