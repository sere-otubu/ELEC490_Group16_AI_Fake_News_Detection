# Capstone RAG System Environment Variables

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Option A: Supabase (recommended) – one URL for both vector store and query history
# Get from Supabase: Project Settings → Database → Connection string (URI)
APP_DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Storage Configuration (for document uploads)
# Get from Supabase: Project Settings → API → Project URL
APP_SUPABASE_URL=https://[project-ref].supabase.co
APP_SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
APP_SUPABASE_BUCKET_NAME=YOUR_BUCKET_NAME

# Option B: Local / custom PostgreSQL – set individual params
# APP_PG_HOST=localhost
# APP_PG_PORT=5433
# APP_PG_USER=postgres
# APP_PG_PASSWORD=lion8833
# APP_PG_DATABASE=capstone_db

# OpenRouter (required)
APP_OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
APP_OPENROUTER_LLM_MODEL=openai/gpt-4o-mini
APP_OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
APP_EMBED_DIM=1536

# =============================================================================
# VECTOR STORE CONFIGURATION
# =============================================================================
APP_VECTOR_TABLE_NAME=knowledge_base

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_DATA_FOLDER=./data

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# API URL for frontend to connect to backend
# Leave empty for production (same-origin requests when served by FastAPI)
# Use http://localhost:8000 for standalone frontend development
VITE_API_BASE_URL=http://localhost:8000

# =============================================================================
# DOCKER DEVELOPMENT NOTES
# =============================================================================
# When running with Docker Compose:
# - Database will be accessible on localhost:5432
# - Ollama will be accessible on localhost:11434  
# - Full application (backend + frontend) will be accessible on localhost:8000
#
# The services communicate internally using Docker service names:
# - backend connects to database via "db:5432"
# - backend connects to ollama via "ollama:11434"
# - frontend is served directly by FastAPI (integrated setup)